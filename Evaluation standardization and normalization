import numpy as np
from sklearn.preprocessing import StandardScaler, MinMaxScaler
from sklearn.metrics import accuracy_score, mean_squared_error

y_actual = [0, 1, 1, 0, 1]
y_predicted = [0, 1, 0, 0, 1]

accuracy = accuracy_score(y_actual, y_predicted)

print("CLASSIFICATION EVALUATION")
print("Accuracy:", accuracy)
print("----------------------------------")

y_actual_reg = [10, 20, 30, 40]
y_predicted_reg = [12, 18, 33, 37]

mse = mean_squared_error(y_actual_reg, y_predicted_reg)

print("REGRESSION EVALUATION")
print("Mean Squared Error (MSE):", mse)
print("----------------------------------")

data = [[10], [20], [30], [40], [50]]

standard_scaler = StandardScaler()
standardized_data = standard_scaler.fit_transform(data)

print("STANDARDIZATION OUTPUT")
print(standardized_data)
print("----------------------------------")

minmax_scaler = MinMaxScaler()
normalized_data = minmax_scaler.fit_transform(data)

print("NORMALIZATION OUTPUT")
print(normalized_data)
print("----------------------------------")

print("Result:")
print("Evaluation metrics calculated successfully.")
print("Data standardized and normalized successfully.")

